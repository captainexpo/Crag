//NAME: Fibb with vector
//DESC:
//BEGIN CODE

import "stdlib" as std;

fn main() -> i32 {
    let a = std.vector.new::<i64>();

    a.append(0);
    a.append(1);
    for (let i: usize = 1; i < 100; i += 1) {
        a.append(a.get(i - 1).ok + a.get(i).ok);
    }
    for (let i: usize = 0; i < 7; i += 1){
        std.cstdio.printf("%lld\n", a.get(i).ok);
    }
    return 0;
}

//END CODE
//BEGIN EXPECT
//0\n
//1\n
//1\n
//2\n
//3\n
//5\n
//8\n
//END EXPECT
