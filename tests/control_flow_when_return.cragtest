//NAME: When Return and Loop Control
//DESC: Tests return inside when and continue/break inside loops with when
//BEGIN CODE

extern fn printf(fmt: *u8, ...) -> i32;

fn main() -> i32 {
  for (let i: i32 = 0; i < 4; i = i + 1) {
    if (i == 1) {
      printf("skip-1\n");
      continue;
    }
    if (i == 3) {
      printf("stop-at-3\n");
      break;
    }
    printf("i=%d\n", i);
  }
  when true {
    printf("after-loop\n");
    return 0;
  }
  printf("should-not-print\n");
  return 0;
}

//END CODE
//BEGIN EXPECT
//i=0
//skip-1
//i=2
//stop-at-3
//after-loop
//END EXPECT
