//NAME: When Target Arch
//DESC: Test braced when blocks with compile-time target architecture string comparison.
//BEGIN CODE

extern fn printf(fmt: *u8, ...) -> i32;

when @target_arch == "x86_64" {
  fn main() -> i32 {
    when @target_os == "linux" { printf("x86_64\n"); }
    when @target_os == "windows" { printf("Windows :("); }
    return 0;
  }
}

when @target_arch != "x86_64" {
  fn main() -> i32 {
    printf("other\n");
    return 0;
  }
}

//END CODE
//BEGIN EXPECT
//x86_64
//END EXPECT
