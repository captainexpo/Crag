//NAME: Implicit generic instancing
//DESC: Test whether the language supports instancing implicitly
//BEGIN CODE

import "stdlib" as std;

fn add_generic<T>(a: T, b: T) -> T {
    return a + b;
}

fn other_generic<T1, T2>(fmt: *const u8, a: T1, b: T2) -> void {
    std::cstdio::printf(fmt, a, b);
}

fn main(argc: i32, argv: **u8) -> i32 {
    // Explicit instancing
    std::cstdio::printf("%f\n", add_generic::<f32>(0.1, 0.2));
    std::cstdio::printf("%d\n", add_generic::<i32>(1, 2));
    other_generic::<i32, f32>("%d %f\n", 5, 0.2);
    other_generic::<bool, usize>("%d %zu\n", true, 42);

    // Implicit instancing
    std::cstdio::printf("%f\n", add_generic(0.1, 0.2));
    std::cstdio::printf("%d\n", add_generic(1, 2));
    other_generic("%d %f\n", 5, 0.2);
    other_generic("%d %zu\n", true, 42);
    return 0;
}


//END CODE
//BEGIN EXPECT
//0.300000
//3
//5 0.200000
//1 42
//0.300000
//3
//5 0.200000
//1 42
//END EXPECT
