//NAME: Aliased Generics
//DESC:
//BEGIN CODE

extern fn printf(fmt: *u8, ...) -> i32;

struct Point<T> {
    x: T,
    y: T,
}

fn identity<T>(x: T) -> T {
    return x;
}

using Palias<T> = Point::<T>;

fn main() -> i32 {
    let p1 = Palias::<i32>{x: 1, y: 2};
    let k = identity::<bool>(true);
    printf("%d\n", p1.x + p1.y + (k as i32));
    return 0;
}

//END CODE
